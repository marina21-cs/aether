# Clerk
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
VITE_APP_URL=http://localhost:3000
VITE_APP_NAME=AETHER

# Market data APIs
VITE_COINGECKO_API_KEY=
VITE_EXCHANGE_RATE_API_KEY=
# Optional webhook quote fetch tuning (milliseconds)
MARKET_QUOTE_TIMEOUT_MS=6000
MARKET_QUOTE_CACHE_TTL_MS=60000

# Optional API host override for frontend requests.
# Leave empty when using same-origin proxy in local dev.
VITE_API_BASE_URL=

# Phase 3: OpenRouter AI Advisor
OPENROUTER_API_KEY=
AI_MODEL=qwen/qwen3-coder:free
# Optional: comma-separated model fallbacks if primary model is throttled.
AI_FALLBACK_MODELS=
# Optional: retry behavior for transient OpenRouter errors (429/5xx).
AI_UPSTREAM_MAX_RETRIES=1
AI_UPSTREAM_RETRY_BASE_MS=800
AI_UPSTREAM_RETRY_MAX_MS=6000
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.3
AI_RATE_LIMIT_FREE=20
AI_RATE_LIMIT_PRO=100
AI_CACHE_TTL=3600000

# Phase 3: PH market context defaults (MVP manual updates)
PH_BSP_RATE=6.25
PH_CPI_RATE=6.1
PH_PSEI_LEVEL=6800

# Phase 3: Glass Box simulation defaults
MONTE_CARLO_PATHS=1000
MONTE_CARLO_HORIZON_YEARS=10

# Phase 4: Simulator + Alerts
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=AETHER <onboarding@resend.dev>
ALERT_CHECK_INTERVAL=300000
MAX_ALERTS_FREE=10
MAX_ALERTS_PRO=50
DIGEST_SEND_DAY=1
DIGEST_SEND_HOUR=8

# Phase 5: Free RAG + Data Pipeline
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.25
# Optional: comma-separated Clerk user IDs that can ingest/update RAG and run pipelines.
RAG_ADMIN_USER_IDS=

# Optional for FX refresh pipeline route (falls back to static defaults when empty).
VITE_EXCHANGE_RATE_API_KEY=
